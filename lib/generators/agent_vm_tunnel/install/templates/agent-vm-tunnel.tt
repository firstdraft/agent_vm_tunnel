#!/usr/bin/env bash
# Reconcile the database, Rails app, and reverse tunnel owned by this project.
# Generated by agent_vm_tunnel. Safe to call repeatedly and concurrently.
set -uo pipefail

ACTION="${1:-ensure}"
case "$ACTION" in ensure|status|stop) ;; *) echo "usage: $0 [ensure|status|stop]" >&2; exit 64;; esac

ROOT="$(cd "$(dirname "$0")/.." && pwd)"; cd "$ROOT" || exit 1
RUNDIR="$ROOT/tmp/agent-vm-tunnel"
CONFIG_FILE="$ROOT/config/agent_vm_tunnel.json"
mkdir -p "$RUNDIR/bin"
umask 077

log() { printf '[agent-vm-tunnel] %s\n' "$*"; }
fail() { printf '[agent-vm-tunnel] %s\n' "$*" >&2; return 1; }

# Serialize hooks and manual invocations. Both supported cloud providers are
# Linux and include flock; the mkdir fallback keeps local runs safe too.
LOCK_DIR=""
if command -v flock >/dev/null 2>&1; then
  exec 9>"$RUNDIR/lock"
  flock -w 30 9 || { fail "another reconciliation did not finish within 30 seconds"; exit 1; }
else
  LOCK_DIR="$RUNDIR/lock.d"
  lock_acquired=false
  for _ in {1..300}; do if mkdir "$LOCK_DIR" 2>/dev/null; then lock_acquired=true; break; fi; sleep 0.1; done
  $lock_acquired || { fail "could not acquire the reconciliation lock"; exit 1; }
  trap 'rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT
fi

# Use exactly the Ruby requested by this app. Never select the lexical last
# hostedtoolcache entry, and never let an unrelated Ruby interpret app commands.
RUBY_VERSION="$(sed -n '1{s/^ruby-//;s/[[:space:]]//g;p;}' .ruby-version 2>/dev/null || true)"
RUBY_BIN=""
if [ -n "$RUBY_VERSION" ]; then
  candidate="/opt/hostedtoolcache/Ruby/$RUBY_VERSION/x64/bin/ruby"
  [ -x "$candidate" ] && RUBY_BIN="$candidate"
  if [ -z "$RUBY_BIN" ] && command -v asdf >/dev/null 2>&1; then
    prefix="$(ASDF_RUBY_VERSION="$RUBY_VERSION" asdf where ruby 2>/dev/null || true)"
    [ -x "$prefix/bin/ruby" ] && RUBY_BIN="$prefix/bin/ruby"
  fi
  if [ -z "$RUBY_BIN" ] && command -v mise >/dev/null 2>&1; then
    prefix="$(mise where "ruby@$RUBY_VERSION" 2>/dev/null || true)"
    [ -x "$prefix/bin/ruby" ] && RUBY_BIN="$prefix/bin/ruby"
  fi
fi
if [ -z "$RUBY_BIN" ] && command -v ruby >/dev/null 2>&1; then
  current="$(ruby -e 'print RUBY_VERSION' 2>/dev/null || true)"
  { [ -z "$RUBY_VERSION" ] || [ "$current" = "$RUBY_VERSION" ]; } && RUBY_BIN="$(command -v ruby)"
fi
[ -n "$RUBY_BIN" ] || { fail "Ruby ${RUBY_VERSION:-from PATH} is unavailable; run cloud-vm-setup.sh"; exit 1; }
RUBY_BINDIR="$(cd "$(dirname "$RUBY_BIN")" && pwd)"
PATH="$RUBY_BINDIR:$RUNDIR/bin:$PATH"; export PATH

digest() { "$RUBY_BIN" -rdigest -e 'print Digest::SHA256.hexdigest(STDIN.read)'; }
ROOT_ID="$(printf '%s' "$ROOT" | digest)"
OWNER="agent-vm-tunnel:$ROOT_ID"

# One JSON file is shared by the Railtie and this script. Environment overrides
# are deliberately named the same on both sides.
[ -f "$CONFIG_FILE" ] || { fail "$CONFIG_FILE is missing; rerun the install generator"; exit 1; }
SETTINGS="$("$RUBY_BIN" -rjson -e '
  data = JSON.parse(File.read(ARGV.fetch(0)))
  host = ENV.fetch("AGENT_VM_TUNNEL_HOST", data.fetch("host", ""))
  fp = ENV.fetch("AGENT_VM_TUNNEL_FINGERPRINT", data.fetch("fingerprint", ""))
  provider = data.fetch("provider", "generic")
  labels = host.split(".")
  abort "invalid tunnel host" unless host.match?(/\A[a-z0-9.-]+\z/) && !host.include?("..") && labels.all? { |l| l.match?(/\A[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\z/) }
  abort "invalid chisel fingerprint" unless fp.match?(/\A[A-Za-z0-9+\/]{43}=\z/)
  abort "invalid provider" unless %w[claude codex both generic].include?(provider)
  STDOUT.write(host, "\t", fp, "\t", provider)
' "$CONFIG_FILE")" || { fail "invalid $CONFIG_FILE"; exit 1; }
IFS=$'\t' read -r TUNNEL_HOST FINGERPRINT PROVIDER <<<"$SETTINGS"
[ -n "$TUNNEL_HOST" ] && [ -n "$FINGERPRINT" ] && [ -n "$PROVIDER" ] || { fail "invalid $CONFIG_FILE"; exit 1; }

# Claude restores /usr/local/bin between sessions. In a Claude runtime, repoint
# it only to the exact app Ruby, never to a wildcard version. The environment
# marker keeps a `both` repository from mutating Codex. Failure is harmless
# because every owned child gets PATH explicitly.
if { [ "$PROVIDER" = claude ] || [ "$PROVIDER" = both ]; } &&
    [ -n "${CLAUDE_PROJECT_DIR:-}" ] && [ -w /usr/local/bin ]; then
  for tool in "$RUBY_BINDIR"/*; do [ -x "$tool" ] && ln -sf "$tool" /usr/local/bin/ 2>/dev/null || true; done
fi

pid_file() { printf '%s/%s.pid' "$RUNDIR" "$1"; }
state_file() { printf '%s/%s.state' "$RUNDIR" "$1"; }
owner_file() { printf '%s/%s.owner' "$RUNDIR" "$1"; }
group_file() { printf '%s/%s.group' "$RUNDIR" "$1"; }

owned_alive() {
  local name="$1" pid marker
  [ -r "$(pid_file "$name")" ] || return 1
  pid="$(<"$(pid_file "$name")")"
  [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null || return 1
  marker="$OWNER:$name"
  if [ -r "/proc/$pid/environ" ]; then
    tr '\0' '\n' <"/proc/$pid/environ" | grep -Fqx "AGENT_VM_TUNNEL_OWNER=$marker"
  else
    [ "$(cat "$(owner_file "$name")" 2>/dev/null)" = "$marker" ]
  fi
}

stop_owned() {
  local name="$1" pid grouped=""
  if owned_alive "$name"; then
    pid="$(<"$(pid_file "$name")")"
    grouped="$(cat "$(group_file "$name")" 2>/dev/null || true)"
    if [ "$grouped" = yes ]; then kill -TERM "-$pid" 2>/dev/null || true
    else kill -TERM "$pid" 2>/dev/null || true; fi
    for _ in {1..50}; do kill -0 "$pid" 2>/dev/null || break; sleep 0.1; done
    if kill -0 "$pid" 2>/dev/null; then
      if [ "$grouped" = yes ]; then kill -KILL "-$pid" 2>/dev/null || true
      else kill -KILL "$pid" 2>/dev/null || true; fi
    fi
  fi
  rm -f "$(pid_file "$name")" "$(state_file "$name")" "$(owner_file "$name")" "$(group_file "$name")"
}

rotate_log() {
  local file="$1" size
  [ -f "$file" ] || return 0
  size="$(wc -c <"$file" 2>/dev/null || printf 0)"
  if [ "$size" -gt 1048576 ]; then mv -f "$file" "$file.previous"; fi
}

start_owned() {
  local name="$1" state="$2" logfile="$3" pid grouped=no
  shift 3
  stop_owned "$name"
  rotate_log "$logfile"
  if command -v setsid >/dev/null 2>&1; then
    # Background children must not inherit the flock descriptor. Otherwise the
    # lock remains held for the lifetime of the app/tunnel after ensure exits.
    setsid env "AGENT_VM_TUNNEL_OWNER=$OWNER:$name" "$@" 9>&- </dev/null >>"$logfile" 2>&1 &
    grouped=yes
  else
    nohup env "AGENT_VM_TUNNEL_OWNER=$OWNER:$name" "$@" 9>&- </dev/null >>"$logfile" 2>&1 &
  fi
  pid=$!
  printf '%s\n' "$pid" >"$(pid_file "$name").tmp"
  printf '%s\n' "$state" >"$(state_file "$name").tmp"
  printf '%s\n' "$OWNER:$name" >"$(owner_file "$name").tmp"
  printf '%s\n' "$grouped" >"$(group_file "$name").tmp"
  mv "$(pid_file "$name").tmp" "$(pid_file "$name")"
  mv "$(state_file "$name").tmp" "$(state_file "$name")"
  mv "$(owner_file "$name").tmp" "$(owner_file "$name")"
  mv "$(group_file "$name").tmp" "$(group_file "$name")"
  sleep 0.2
  owned_alive "$name" || { fail "$name exited during launch; see $logfile"; stop_owned "$name"; return 1; }
}

state_matches() { [ "$(cat "$(state_file "$1")" 2>/dev/null)" = "$2" ]; }

tcp_ready() {
  PORT_TO_CHECK="$1" "$RUBY_BIN" -rsocket -rtimeout -e '
    Timeout.timeout(1) { TCPSocket.new("127.0.0.1", Integer(ENV.fetch("PORT_TO_CHECK"))).close }
  ' >/dev/null 2>&1
}

wait_for_tcp() {
  local port="$1"
  for _ in {1..100}; do tcp_ready "$port" && return 0; sleep 0.1; done
  return 1
}

if [ "$ACTION" = stop ]; then
  stop_owned tunnel; stop_owned app
  log "stopped owned app and tunnel processes"
  exit 0
fi

if [ "$ACTION" = status ]; then
  for name in app tunnel; do
    if owned_alive "$name"; then log "$name: running (pid $(<"$(pid_file "$name")"))"
    else log "$name: stopped"; fi
  done
  exit 0
fi

# Removing or corrupting the credential must close any previously owned tunnel.
if [ -z "${AGENT_VM_TUNNEL:-}" ]; then
  was_running=false; owned_alive tunnel && was_running=true
  stop_owned tunnel
  $was_running && log "credential removed; stopped the old tunnel"
  exit 0
fi
SLOT_NN="${AGENT_VM_TUNNEL%%:*}"; PASS="${AGENT_VM_TUNNEL#*:}"
if [ "$SLOT_NN" = "$AGENT_VM_TUNNEL" ] || [ -z "$PASS" ] || ! [[ "$SLOT_NN" =~ ^[1-9][0-9]{0,3}$ ]]; then
  stop_owned tunnel
  fail "AGENT_VM_TUNNEL must look like N:pass (slot 1-9999); stopped any old tunnel"
  exit 64
fi
PORT=$((20000 + 10#$SLOT_NN)); CHISEL_USER="slot${SLOT_NN}"

APP_PORT="${APP_PORT:-3000}"
if ! [[ "$APP_PORT" =~ ^[0-9]+$ ]] || [ "$APP_PORT" -lt 1 ] || [ "$APP_PORT" -gt 65535 ]; then
  fail "APP_PORT must be between 1 and 65535"; exit 64
fi

detect_db_adapter() {
  if [ -n "${DATABASE_ADAPTER:-}" ]; then printf '%s' "$DATABASE_ADAPTER"; return; fi
  "$RUBY_BIN" -rerb -ryaml -e '
    begin
      raw = ERB.new(File.read("config/database.yml")).result
      data = YAML.safe_load(raw, aliases: true) || {}
      env = ENV.fetch("RAILS_ENV", "development")
      value = data[env]
      value = data[value.delete_prefix("*")] if value.is_a?(String) && value.start_with?("*")
      puts(value["adapter"] || value[:adapter]) if value.respond_to?(:[])
    rescue StandardError
    end
  ' 2>/dev/null | head -n1
}

DB_ADAPTER="$(detect_db_adapter)"
case "$DB_ADAPTER" in
  postgresql|postgres|pg)
    if ! pg_isready -q 2>/dev/null; then
      (service postgresql start || sudo -n service postgresql start) >/dev/null 2>&1 || true
      for _ in {1..100}; do pg_isready -q 2>/dev/null && break; sleep 0.1; done
      pg_isready -q 2>/dev/null || { fail "PostgreSQL did not become ready"; exit 1; }
      db_started=postgres
    fi ;;
  mysql|mysql2|trilogy)
    if ! mysqladmin ping -s >/dev/null 2>&1; then
      (service mariadb start || sudo -n service mariadb start) >/dev/null 2>&1 || true
      for _ in {1..100}; do mysqladmin ping -s >/dev/null 2>&1 && break; sleep 0.1; done
      mysqladmin ping -s >/dev/null 2>&1 || { fail "MariaDB did not become ready"; exit 1; }
      db_started=mariadb
    fi ;;
esac

if [ -x bin/dev ]; then APP_COMMAND=(env -u AGENT_VM_TUNNEL "PORT=$APP_PORT" "APP_PORT=$APP_PORT" bin/dev)
else APP_COMMAND=(env -u AGENT_VM_TUNNEL "PORT=$APP_PORT" "APP_PORT=$APP_PORT" bin/rails server -b 127.0.0.1 -p "$APP_PORT"); fi
APP_STATE="$(printf '%s\0' "$APP_PORT" "${APP_COMMAND[@]}" | digest)"
app_changed=false
if ! owned_alive app || ! state_matches app "$APP_STATE" || ! tcp_ready "$APP_PORT"; then
  stop_owned app
  if tcp_ready "$APP_PORT"; then fail "port $APP_PORT is occupied by a process this project does not own"; exit 1; fi
  start_owned app "$APP_STATE" "$RUNDIR/app.log" "${APP_COMMAND[@]}" || exit 1
  if ! wait_for_tcp "$APP_PORT"; then fail "app did not listen on 127.0.0.1:$APP_PORT; see $RUNDIR/app.log"; stop_owned app; exit 1; fi
  app_changed=true
fi

CHISEL_VERSION="1.11.5"
install_chisel() {
  local arch checksum asset tmp actual
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64; checksum=2506226c4710a3c8d3b332f83d0f3b412fe2a8436b710ea0dbec44b288ab309b ;;
    aarch64|arm64) arch=arm64; checksum=1a4f16aad733f022b9aa90903268d730bfb20b03f9484f7ab4863e442737fa9a ;;
    *) fail "chisel has no pinned binary for architecture $(uname -m)"; return 1 ;;
  esac
  asset="chisel_${CHISEL_VERSION}_linux_${arch}.gz"
  tmp="$RUNDIR/$asset.tmp"
  curl --proto '=https' --tlsv1.2 -fsSL --retry 3 --connect-timeout 10 --max-time 90 \
    "https://github.com/jpillora/chisel/releases/download/v${CHISEL_VERSION}/${asset}" -o "$tmp" || return 1
  actual="$("$RUBY_BIN" -rdigest -e 'print Digest::SHA256.file(ARGV.fetch(0)).hexdigest' "$tmp")"
  [ "$actual" = "$checksum" ] || { rm -f "$tmp"; fail "chisel checksum mismatch"; return 1; }
  gunzip -c "$tmp" >"$RUNDIR/bin/chisel.new" || { rm -f "$tmp" "$RUNDIR/bin/chisel.new"; return 1; }
  chmod 0755 "$RUNDIR/bin/chisel.new" && mv -f "$RUNDIR/bin/chisel.new" "$RUNDIR/bin/chisel"
  rm -f "$tmp"
}

CHISEL_BIN="$(command -v chisel 2>/dev/null || true)"
if [ -z "$CHISEL_BIN" ]; then install_chisel || { fail "could not install verified chisel $CHISEL_VERSION"; exit 1; }; CHISEL_BIN="$RUNDIR/bin/chisel"; fi

DEFAULT_CONNECT_URL="https://tunnel.$TUNNEL_HOST"
fetch_connect_url() {
  local body
  body="$(curl --proto '=https' --tlsv1.2 -fsS --connect-timeout 3 --max-time 5 "https://$TUNNEL_HOST/tunnel" 2>/dev/null)" || return 1
  EXPECTED_HOST="tunnel.$TUNNEL_HOST" "$RUBY_BIN" -rjson -ruri -e '
    data = JSON.parse(STDIN.read)
    uri = URI.parse(data.fetch("connect_url"))
    abort unless %w[https wss].include?(uri.scheme)
    abort unless uri.host == ENV.fetch("EXPECTED_HOST") && uri.userinfo.nil?
    abort unless uri.port == 443 && (uri.path.empty? || uri.path == "/") && uri.query.nil? && uri.fragment.nil?
    print uri.to_s
  ' <<<"$body" 2>/dev/null
}

CONNECT_URL="$(fetch_connect_url || true)"
if [ -z "$CONNECT_URL" ]; then
  cached="$(cat "$RUNDIR/connect-url" 2>/dev/null || true)"
  CONNECT_URL="${cached:-$DEFAULT_CONNECT_URL}"
else
  printf '%s\n' "$CONNECT_URL" >"$RUNDIR/connect-url.tmp" && mv "$RUNDIR/connect-url.tmp" "$RUNDIR/connect-url"
fi

TUNNEL_STATE="$(printf '%s\0' "$SLOT_NN" "$PASS" "$APP_PORT" "$CONNECT_URL" "$FINGERPRINT" "${HTTPS_PROXY:-${https_proxy:-}}" "${CHISEL_CA:-}" | digest)"
TUNNEL_COMMAND=(env "AUTH=${CHISEL_USER}:${PASS}" "$CHISEL_BIN" client --fingerprint "$FINGERPRINT" --keepalive 25s)
PROXY="${HTTPS_PROXY:-${https_proxy:-}}"; [ -n "$PROXY" ] && TUNNEL_COMMAND+=(--proxy "$PROXY")
if [ -n "${CHISEL_CA:-}" ] && [ -f "$CHISEL_CA" ]; then TUNNEL_COMMAND+=(--tls-ca "$CHISEL_CA")
elif [ -f /root/.ccr/ca-bundle.crt ]; then TUNNEL_COMMAND+=(--tls-ca /root/.ccr/ca-bundle.crt); fi
TUNNEL_COMMAND+=("$CONNECT_URL" "R:127.0.0.1:${PORT}:localhost:${APP_PORT}")

tunnel_changed=false
if ! owned_alive tunnel || ! state_matches tunnel "$TUNNEL_STATE"; then
  start_owned tunnel "$TUNNEL_STATE" "$RUNDIR/tunnel.log" "${TUNNEL_COMMAND[@]}" || exit 1
  sleep 1
  owned_alive tunnel || { fail "tunnel process did not stay running; see $RUNDIR/tunnel.log"; exit 1; }
  tunnel_changed=true
fi

if $app_changed || $tunnel_changed || [ -n "${db_started:-}" ]; then
  parts=(); [ -n "${db_started:-}" ] && parts+=("$db_started ready"); $app_changed && parts+=("app ready on $APP_PORT"); $tunnel_changed && parts+=("tunnel process launched for slot $SLOT_NN")
  log "${parts[*]}"
fi
